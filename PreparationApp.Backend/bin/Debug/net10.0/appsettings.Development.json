{
  // --> Config. des niveaux de journalisation (logs) pour le développement
  // En développement, on utilise un niveau de log plus détaillé pour déboguer.
  // "Default": "Debug" permet d'avoir plus d'informations dans les logs.
  // "Microsoft": "Warning" réduit le bruit des logs des bibliothèques Microsoft.
  // "Microsoft.Hosting.Lifetime": "Information" pour voir les messages de démarrage.
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  // --> Chaîne de connexion pour le développement
  // Utilise une base de données locale ou de développement.
  // Écrasera la valeur de "DefaultConnection" dans appsettings.json.
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PreparationApp_Dev;Trusted_Connection=True;TrustServerCertificate=True;"
    // Exemple pour une base de données locale en développement.
    // Remplace "PreparationApp_Dev" par le nom de ta base de données de test.
  },

  // --> Config. pour les services Google en développement
  // Peut écraser ou compléter les valeurs de "Google" dans appsettings.json.
  // Exemple : Utiliser des clefs de test en développement.
  "Google": {
    // Si clefs spécifiques pour le développement, ajouter ici.
    // Sinon, les valeurs de appsettings.json seront utilisées.
    "ClientId": "mon_client_id_dev.apps.googleusercontent.com",
    "ClientSecret": "mon_client_secret_dev"
  },

  // --> Config. pour Swagger en développement
  // Active Swagger uniquement en développement.
  // RoutePrefix et JsonRoute doivent correspondre à SwaggerDoc("v1") dans Program.cs.
  "Swagger": {
    "Enabled": true,
    "Title": "PreparationApp API (Dev)",
    "Version": "v1",
    "Description": "API de développement pour gérer les préparations, formateurs et rapports.",
    "RoutePrefix": "swagger",
    "JsonRoute": "swagger/v1/swagger.json"
  },

  // --> Autres paramètres utiles pour le développement
  // Désactive la validation des tokens JWT en développement.
  "Jwt": {
    "ValidateIssuer": false,
    "ValidateAudience": false
  }
}