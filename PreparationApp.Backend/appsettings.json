{
  // --> Chaînes de connexion
  // Définit les connexions aux bases de données ou autres services.
  // "DefaultConnection" est utilisée par AppDbContext dans Program.cs.

  "ConnectionStrings": {
    "DefaultConnection": "Server=mon_serveur_sql_server;Database=PreparationApp;Trusted_Connection=True;TrustServerCertificate=True;"
    // Exemple pour SQL Server avec authentification Windows.
    // Remplace "mon_serveur_sql_server" par le nom de mon serveur (ex: "localhost" ou ".\SQLEXPRESS").
    // TrustServerCertificate=True : Désactive la validation du certificat SSL (pour le développement uniquement).
  },

  // --> Config. des niveaux de journalisation (logs)
  // Définit les niveaux de journalisation pour différentes parties de l'application.
  // "Default" : Niveau de log par défaut pour toute l'application.
  // "Microsoft.AspNetCore" : Niveau de log spécifique pour les composants ASP.NET Core.
  // Niveaux possibles : Trace < Debug < Information < Warning < Error < Critical < None

  "Logging": {
    "LogLevel": {
      "Default": "Information",  // En production, on utilise généralement "Information" ou "Warning".
      "Microsoft.AspNetCore": "Warning"  // Réduit le bruit des logs pour ASP.NET Core.
    }
  },

  // --> Hôtes autorisés (CORS)
  // Définit les hôtes autorisés à accéder à mon API (pour éviter les erreurs CORS).
  // "*" : Autorise tous les hôtes (à utiliser uniquement en développement !).
  // En production, remplace par les domaines spécifiques (ex: ["https://monapp.com"]).
  "AllowedHosts": "*",

  // --> Config. pour Swagger
  // Swagger est utilisé pour documenter et tester mon API.
  // Ces paramètres permettent de personnaliser l'affichage et le comportement de Swagger UI.
  "Swagger": {
    // Active ou désactive Swagger (utile pour le désactiver en production).
    "Enabled": true,

    // Titre de l'API affiché dans Swagger UI.
    "Title": "PreparationApp API",

    // Version de l'API affiché dans Swagger UI.
    "Version": "v1",

    // Description de l'API (optionnel).
    "Description": "API pour gérer les préparations, formateurs et rapports.",

    // URL de base pour Swagger JSON (généré automatiquement).
    "RoutePrefix": "swagger",

    // Chemin vers le fichier JSON de Swagger (généré automatiquement).
    "JsonRoute": "swagger/v1/swagger.json"
  },

  // --> Config. pour les services Google
  // Ces clefs sont utilisées par GoogleCalendarService et GoogleSheetsService.
  // Elles sont injectées via IConfiguration dans les services.

  "Google": {
    // Clef client pour l'authentification OAuth 2.0 avec Google.
    // Récupérée depuis Google Cloud Console > APIs & Services > Credentials.
    "ClientId": "mon_client_id_google.apps.googleusercontent.com",

    // Secret client pour l'authentification OAuth 2.0 avec Google.
    // À garder secret !!! Ne jamais commiter ce fichier en public.
    "ClientSecret": "mon_client_secret_google",

    // JSON des credentials pour les API Google (Service Account)
    // Ce bloc doit être remplacé par le contenu du fichier JSON téléchargé depuis Google Cloud Console.
    // Utilisé par GoogleCredential.FromJson() dans les services.

    "Credentials": {
      "type": "service_account",
      "project_id": "mon_projet_id",

      "private_key_id": "ma_clef_privee_id",

      // La clef privée doit être au format PEM (avec les balises BEGIN/END PRIVATE KEY).
      "private_key": "-----BEGIN PRIVATE KEY-----\nma_clef_privee\n-----END PRIVATE KEY-----\n",
      "client_email": "mon_email_service@mon_projet.iam.gserviceaccount.com",
      "client_id": "mon_client_id",
      "auth_uri": "https://accounts.google.com/o/oauth2/auth",
      "token_uri": "https://oauth2.googleapis.com/token",
      "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
      "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/mon_email_service%40mon_projet.iam.gserviceaccount.com"
    }
  }
}